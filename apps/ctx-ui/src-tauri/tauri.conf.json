{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ctx",
  "version": "1.0.1",
  "identifier": "com.jaykumargaur.ctx",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "popover",
        "title": "Ctx",
        "width": 400,
        "height": 560,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "alwaysOnTop": true,
        "focus": true,
        "shadow": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlDNDMxMDZBMEY0MTY2NApSV1JrRnZTZ0JqSEVDWCsyZi9TbHZQOVFMdU5yRmhxOS9TckRnT0dUMjBnN0kzWHBTd2hkS29nNwo=",
      "endpoints": [
        "https://github.com/Jaygaur99/ctx/releases/latest/download/latest.json"
      ]
    }
  }
}

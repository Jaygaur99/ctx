{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ctx",
  "version": "0.2.0",
  "identifier": "com.jaykumargaur.ctx",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "popover",
        "title": "Ctx",
        "width": 400,
        "height": 560,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "alwaysOnTop": true,
        "focus": true,
        "shadow": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-"
    }
  }
}
